---
// src/layouts/Layout.astro
import '../styles/global.css';

// Τα props είναι οι "παράμετροι" που δέχεται το layout
// π.χ. <Layout title="Login" />
const { title = "Saloon Pro" } = Astro.props;
---

<!doctype html>
<html lang="el">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-[#0b0f1a] text-white selection:bg-indigo-500/30 antialiased">
		<slot />
	</body>
</html>